generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VaiTro {
  ADMIN
  BGH
  GIAOVIEN
  TAICHINH
  PHUHUYNH
}

model nguoidung {
  idND        String  @id @db.VarChar(191)
  tenDangNhap String  @unique @db.VarChar(191)
  matKhau     String  @db.VarChar(191)
  email       String? @db.VarChar(191)
  soDienThoai String? @db.VarChar(191)
  vaiTro      VaiTro

  admin       admin?
  bangiamhieu bangiamhieu?
  giaovien    giaovien?
  taichinh    taichinh?
  phuhuynh    phuhuynh?

  thongBaoGui thongbao[] @relation("NguoiGui_ThongBao")
}

model admin {
  maAdmin   String @id @db.VarChar(191)
  hoTen     String @db.VarChar(191)
  nguoiDung String @unique @db.VarChar(191)

  nguoidung_rel nguoidung @relation(fields: [nguoiDung], references: [idND])
}

model bangiamhieu {
  maBGH     String  @id @db.VarChar(191)
  hoTen     String  @db.VarChar(191)
  chucVu    String? @db.VarChar(191)
  nguoiDung String  @unique @db.VarChar(191)

  nguoidung_rel nguoidung @relation(fields: [nguoiDung], references: [idND])

  lopHoc lophoc[]
}

model giaovien {
  maGV      String @id @db.VarChar(191)
  hoTen     String @db.VarChar(191)
  nguoiDung String @unique @db.VarChar(191)

  ngaySinh  DateTime?
  gioiTinh  String?
  diaChi    String?
  chuyenMon String?

  nguoidung_rel nguoidung @relation(fields: [nguoiDung], references: [idND])

  lopHoc  lophoc[]
  hocSinh hocsinh[]

  diemDanh     diemdanh[]
  bangDiem     bangdiem[]
  danhGia      danhgia[]
  lichGiangDay lichgiangday[]
}

model lichgiangday {
  id          String    @id @default(cuid()) @db.VarChar(191)
  thu         Int // Thứ 2 -> 7 (hoặc 8 cho Chủ nhật)
  caHoc       String    @db.VarChar(191) // Sáng, Chiều, hoặc tiết 1, 2...
  monHoc      String?   @db.VarChar(191)
  ngayHieuLuc DateTime?

  maGV     String   @db.VarChar(191)
  giaoVien giaovien @relation(fields: [maGV], references: [maGV])

  maLop String @db.VarChar(191)
  lop   lophoc @relation(fields: [maLop], references: [maLop])
}

model taichinh {
  maTC      String @id @db.VarChar(191)
  hoTen     String @db.VarChar(191)
  nguoiDung String @unique @db.VarChar(191)

  nguoidung_rel nguoidung @relation(fields: [nguoiDung], references: [idND])

  thuChi thuchi[]
}

model phuhuynh {
  maPH      String @id @db.VarChar(191)
  hoTen     String @db.VarChar(191)
  nguoiDung String @unique @db.VarChar(191)

  nguoidung_rel nguoidung @relation(fields: [nguoiDung], references: [idND])

  hocSinh hocsinh[]
}

model lophoc {
  maLop  String @id @db.VarChar(191)
  tenLop String
  siSo   Int?

  giaoVienId String?
  giaoVien   giaovien? @relation(fields: [giaoVienId], references: [maGV])

  bghId String?
  bgh   bangiamhieu? @relation(fields: [bghId], references: [maBGH])

  hocSinh      hocsinh[]
  lichGiangDay lichgiangday[]
}

model hocsinh {
  maHS     String    @id @db.VarChar(191)
  hoTen    String
  ngaySinh DateTime?
  gioiTinh String?

  lopId String?
  lop   lophoc? @relation(fields: [lopId], references: [maLop])

  giaoVienId String?
  giaoVien   giaovien? @relation(fields: [giaoVienId], references: [maGV])

  phuHuynhId String?
  phuHuynh   phuhuynh? @relation(fields: [phuHuynhId], references: [maPH])

  sucKhoe  suckhoe[]
  diemDanh diemdanh[]
  bangDiem bangdiem[]
  danhGia  danhgia[]
}

model suckhoe {
  maSK        String    @id @db.VarChar(191)
  chieuCao    Float?
  canNang     Float?
  tinhTrang   String?
  ngayKiemTra DateTime?

  hocSinhId String
  hocSinh   hocsinh @relation(fields: [hocSinhId], references: [maHS])
}

model thuchi {
  maTC   String   @id @db.VarChar(191)
  loai   String
  soTien Float
  ngay   DateTime

  taiChinhId String
  taiChinh   taichinh @relation(fields: [taiChinhId], references: [maTC])
}

model thongbao {
  maTB    String   @id @db.VarChar(191)
  tieuDe  String
  noiDung String
  ngayGui DateTime @default(now())

  nguoiGuiId String
  nguoiGui   nguoidung @relation("NguoiGui_ThongBao", fields: [nguoiGuiId], references: [idND])
}

model diemdanh {
  id        String   @id @default(cuid()) @db.VarChar(191)
  ngay      DateTime
  trangThai String   @db.VarChar(191) // CoMat, VangCoPhep, VangKhongPhep
  ghiChu    String?  @db.VarChar(191)

  hocSinhId String  @db.VarChar(191)
  hocSinh   hocsinh @relation(fields: [hocSinhId], references: [maHS], onDelete: Cascade)

  giaoVienId String?   @db.VarChar(191)
  giaoVien   giaovien? @relation(fields: [giaoVienId], references: [maGV])
}

model bangdiem {
  id      String  @id @default(cuid()) @db.VarChar(191)
  monHoc  String  @db.VarChar(191)
  diemSo  Float?
  nhanXet String? @db.VarChar(191)
  kyHoc   String  @db.VarChar(191)
  namHoc  String  @db.VarChar(191)

  hocSinhId String  @db.VarChar(191)
  hocSinh   hocsinh @relation(fields: [hocSinhId], references: [maHS], onDelete: Cascade)

  giaoVienId String?   @db.VarChar(191)
  giaoVien   giaovien? @relation(fields: [giaoVienId], references: [maGV])
}

model danhgia {
  id           String  @id @default(cuid()) @db.VarChar(191)
  kyHoc        String  @db.VarChar(191)
  namHoc       String  @db.VarChar(191)
  nhanXetChung String  @db.Text
  xepLoai      String? @db.VarChar(191)

  hocSinhId String  @db.VarChar(191)
  hocSinh   hocsinh @relation(fields: [hocSinhId], references: [maHS], onDelete: Cascade)

  giaoVienId String?   @db.VarChar(191)
  giaoVien   giaovien? @relation(fields: [giaoVienId], references: [maGV])
}
